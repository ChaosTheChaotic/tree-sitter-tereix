    "description": "Tree-sitter grammar for Tereix",
    "authors": [
      {
        "name": "ChaosTheChaotic",
        "url": "https://github.com/ChaosTheChaotic"
      }
    ],
    "links": {
      "repository": "https://github.com/ChaosTheChaotic/tree-sitter-tereix.git",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": true
